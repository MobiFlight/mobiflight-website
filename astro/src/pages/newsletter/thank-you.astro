---
import Default from "@/layouts/default.astro"
import Container from "@/components/mobiflight/container.astro"
import Hero from "@/components/mobiflight/hero.astro"
import IconCheckCircle from "@/components/mobiflight/icons/icon-check-circle.astro"
import MemberJoinBox from "@/components/mobiflight/member/join-box.astro"
import Link from "@/components/mobiflight/link.astro"

const heroImage =
  "https://shop.mobiflight.com/wp-content/uploads/2026/02/homepage-mcp.jpg"
---

<Default
  title="MobiFlight — Soar Higher with the Ultimate Flight Sim Hardware Companion"
>
  <Hero
    headline="Stay in touch with MobiFlight"
    tagline="Subscribe to our newsletter."
    ctas={[]}
    imageSrc={heroImage}
  />
  <Container class="py-16 pb-16">
    <div class="flex flex-row gap-4 items-center [&>svg]:size-10 [&>svg]:text-green-600 rounded-xl border p-6">
      <IconCheckCircle />
      <div class="flex flex-col gap-2">
        <h2 class="text-3xl font-bold">Thank You!</h2>
        <p class="flex flex-row gap-2">
          You have successfully joined our subscriber list.
        </p>
      </div>
    </div>
  </Container>
  <Container class="flex flex-col gap-4">
    <h2 class="text-3xl font-bold">Want more?</h2>
    <p>
      Become a <Link link="/club" class="font-bold">MobiFlight Club Member</Link
      > and play a crucial role in the MobiFlight community and <Link
        link="/club">enjoy exclusive benefits.</Link>
    </p>
    <MemberJoinBox />
  </Container>
</Default>

---
import Default from "@/layouts/default.astro"
import Hero from "@/components/mobiflight/hero.astro"
import Container from "@/components/mobiflight/container.astro"
import Button from "@/components/starwind/button/Button.astro"
import Link from "@/components/mobiflight/link.astro"
import YoutubeVideo from "@/components/mobiflight/youtube-video.astro"
import IconBulb from "@/components/mobiflight/icons/icon-bulb.astro"
import Card from "@/components/starwind/card/Card.astro"
import CardContent from "@/components/starwind/card/CardContent.astro"
import GettingStartedImage from "@/images/download/getting-started.jpg"
import OctocatImage from "@/images/download/octocat.png"
import PaypalImage from "@/images/download/paypal.png"
import ShopImage from "@/images/download/shop.jpg"
import DiscordImage from "@/images/download/discord.jpg"

const heroImage =
  "https://shop.mobiflight.com/wp-content/uploads/2026/02/homepage-mcp.jpg"
const installerUrl =
  "https://mobiflight.com/tl_files/download/releases/installer/1.5.0/mobiflight-setup.exe"
const clubSignupUrl =
  import.meta.env.PUBLIC_CLUB_SIGNUP_URL ||
  "https://club.mobiflight.com/subscribe"
const donatePaypalUrl = import.meta.env.PUBLIC_DONATE_PAYPAL_URL || "/donate"
const githubSponsorUrl =
  import.meta.env.PUBLIC_GITHUB_SPONSOR_URL ||
  "https://github.com/sponsors/MobiFlight"
const shopUrl = import.meta.env.PUBLIC_SHOP_URL || "https://shop.mobiflight.com"
const docsUrl = import.meta.env.PUBLIC_DOCS_URL || "https://docs.mobiflight.com"
const gettingStartedVideoUrl =
  import.meta.env.PUBLIC_GETTING_STARTED_VIDEO_URL ||
  "https://www.youtube.com/embed/pS8KGfYRNrY?si=i0Bdz6K9lbW5Ocl0"
const youtubeChannelUrl =
  import.meta.env.PUBLIC_YOUTUBE_CHANNEL_URL ||
  "https://www.youtube.com/@MobiFlight/videos"
---

<Default title="Thanks for downloading MobiFlight">
  <Hero
    headline="Thanks for downloading MobiFlight"
    tagline="Your installer should start automatically. While you wait, here are the best next steps."
    imageSrc={heroImage}
  />

  <!-- Download status -->
  <Container class="mt-4">
    <section
      class="shadow-md border-2 bg-primary/5 rounded-md px-8 py-4 flex flex-row items-center gap-2"
    >
      <div class="text-primary">
        <IconBulb />
      </div>
      <p class="text-muted-foreground">
        Your download should start automatically. If it does not, <Link
          id="download-link"
          link={installerUrl}
          rel="noopener noreferrer"
          class="text-primary"
          >click here to manually download the installer</Link
        >.
      </p>
    </section>
  </Container>

  <!-- Step 1: Docs and video -->
  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-2">Step 1: Learn the basics</h2>
      <p class="text-muted-foreground mb-6">
        Start with the quick-start docs and the getting-started video to
        configure your first working setup.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-4">
          <div class="h-70">
            <img
              src={GettingStartedImage.src}
              alt="Documentation preview"
              class="object-cover h-full w-full"
            />
          </div>
          <h3 class="text-xl font-semibold">Quick-start documentation</h3>
          <p class="text-sm text-muted-foreground">
            Follow the starter guide for MSFS and X-Plane, from first connection
            to first working button mapping.
          </p>
          <Button
            href={docsUrl}
            target="_blank"
            rel="noopener noreferrer"
            variant="outline"
          >
            Open the docs
          </Button>
        </div>
        <div class="flex flex-col gap-4">
          <div class="h-70">
            <YoutubeVideo
              src={gettingStartedVideoUrl}
              title="Getting started video"
              class="h-full w-full"
            />
          </div>
          <h3 class="text-xl font-semibold">Getting started video</h3>
          <p class="text-sm text-muted-foreground">
            Watch the full walkthrough and see how a complete setup is built
            from install to first flight.
          </p>
          <Button
            href={youtubeChannelUrl}
            target="_blank"
            rel="noopener noreferrer"
            variant="outline"
          >
            Watch on YouTube
          </Button>
        </div>
      </div>
    </section>
  </Container>

  <!-- Step 2: Support and club -->
  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-2">
        Step 2: Support the project and join the club
      </h2>
      <p class="text-muted-foreground mb-6">
        MobiFlight is free and open source. If it helps your sim experience, you
        can support development and unlock more community benefits.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <article class="p-6 flex flex-col gap-4">
          <div class="h-70 grid grid-cols-2 gap-4">
            <img
              src={OctocatImage.src}
              alt="GitHub logo"
              class="object-cover h-full w-full"
            />
            <img
              src={PaypalImage.src}
              alt="PayPal logo"
              class="object-contain h-full w-full"
            />
          </div>
          <h3 class="text-xl font-semibold">Donate and sponsor</h3>
          <p class="text-sm text-muted-foreground">
            Help keep MobiFlight free for everyone by supporting recurring
            development and maintenance.
          </p>
          <div class="flex gap-3 flex-wrap">
            <Button
              href={githubSponsorUrl}
              target="_blank"
              rel="noopener noreferrer"
              variant="outline"
            >
              Sponsor on GitHub
            </Button>
            <Button
              href={donatePaypalUrl}
              target="_blank"
              rel="noopener noreferrer"
              variant="outline"
            >
              Donate via PayPal
            </Button>
          </div>
        </article>
        <article class="p-6 flex flex-col gap-4">
          <Card
            class="h-70 shadow-lg border-2 bg-primary/5 text-center items-center justify-center"
          >
            <CardContent class="flex flex-col items-center gap-4">
              <div class="flex flex-col gap-1 justify-center items-center">
                <p class="text-lg">Join today for only</p>
                <p class="text-6xl font-bold">5 EUR</p>
                <p class="text-xl text-muted-foreground">per month</p>
              </div>
              <div class="flex justify-center">
                <Button variant="primary" href={clubSignupUrl}
                  >Become a member</Button
                >
              </div>
            </CardContent>
          </Card>
          <h3 class="text-xl font-semibold">Membership and MobiFlight Club</h3>
          <p class="text-sm text-muted-foreground">
            Join the club for a closer connection to the community and future
            member-focused features at club.mobiflight.com.
          </p>
          <div>
            <Button href="/club" variant="outline">
              Learn about the club
            </Button>
          </div>
        </article>
      </div>
    </section>
  </Container>

  <!-- Step 3: Shop and hardware -->
  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-2">
        Step 3: Get hardware and start building
      </h2>
      <p class="text-muted-foreground mb-6">
        Visit the community shop for starter-compatible hardware and accessories
        you can use immediately with MobiFlight.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
        <div class="h-70">
          <img
            src={ShopImage.src}
            alt="Documentation preview"
            class="object-cover h-full w-full"
          />
        </div>
        <div class="md:col-span-1 flex flex-col items-start gap-4">
          <h3 class="text-xl font-semibold">MobiFlight Community Shop</h3>
          <p class="text-sm text-muted-foreground">
            Boards, modules, and cockpit accessories selected to work well with
            the MobiFlight ecosystem.
          </p>
          <Button
            href={shopUrl}
            target="_blank"
            rel="noopener noreferrer"
            variant="outline"
          >
            Visit the shop
          </Button>
        </div>
      </div>
    </section>
  </Container>

  <!-- Step 4: Join the Community -->
  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-2">
        Step 4: Get support and share your progress
      </h2>
      <p class="text-muted-foreground mb-6">
        Join our Discord server to share your progress, ask questions, and
        connect with other MobiFlight builders and sim pilots around the world.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
        <div class="h-70">
          <img
            src={DiscordImage.src}
            alt="Documentation preview"
            class="object-cover h-full w-full"
          />
        </div>
        <div class="md:col-span-1 flex flex-col items-start gap-4">
          <h3 class="text-xl font-semibold">MobiFlight Discord Community</h3>
          <p class="text-sm text-muted-foreground">
            The heart of the MobiFlight ecosystem is the people who use it, and
            our Discord server is where they come together to help each other
            and share their creations.
          </p>
          <Button
            href="https://moibiflight.com/discord"
            target="_blank"
            rel="noopener noreferrer"
            variant="outline"
          >
            Join the Discord
          </Button>
        </div>
      </div>
    </section>
  </Container>
</Default>

<script is:inline>
  // Trigger the download automatically when the page loads
  window.addEventListener("DOMContentLoaded", () => {
    const downloadLink = document.getElementById("download-link")
    if (downloadLink) {
      setTimeout(() => {
        downloadLink.click()
      }, 3000) // Delay to ensure the page has loaded
    }
  })
</script>

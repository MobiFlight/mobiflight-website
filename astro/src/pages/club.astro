---
import Default from "../layouts/default.astro"
import Hero from "@/components/mobiflight/hero.astro"
import Container from "@/components/mobiflight/container.astro"
import IconMilitaryAward from "@/components/mobiflight/icons/icon-military-award.astro"
import IconHeartDollar from "@/components/mobiflight/icons/icon-heart-dollar.astro"
import IconSpeakerphone from "@/components/mobiflight/icons/icon-speakerphone.astro"
import IconDiscount from "@/components/mobiflight/icons/icon-discount.astro"
import IconNews from "@/components/mobiflight/icons/icon-news.astro"
import IconSparkles from "@/components/mobiflight/icons/icon-sparkles.astro"
import heroImage from "@/images/hero-club.jpg"
import MemberJoinBox from "@/components/mobiflight/member/join-box.astro"

const clubSignupUrl = import.meta.env.PUBLIC_CLUB_SIGNUP_URL || "https://club.mobiflight.com/subscribe"
const clubLoginUrl = import.meta.env.PUBLIC_CLUB_LOGIN_URL || "https://club.mobiflight.com"

const benefits = [
  {
    icon: IconHeartDollar,
    iconClass: "text-red-600",
    title: "Support the Project",
    description: "Membership directly funds open-source development.",
  },
  {
    icon: IconSpeakerphone,
    iconClass: "text-primary",
    title: "Get a voice",
    description: "Help us prioritize features and improvements.",
  },
  {
    icon: IconMilitaryAward,
    iconClass: "text-yellow-500",
    title: "Member Badge",
    description: "Recognized role in the Discord community server.",
  },
  {
    icon: IconDiscount,
    iconClass: "text-green-600",
    title: "Special Discounts",
    description: "Member pricing on hardware, events and merchandise.",
  },
  {
    icon: IconNews,
    iconClass: "text-orange-600",
    title: "Hear it first",
    description:
      "Exclusive updates, behind-the-scenes insights, upcoming events.",
  },
  {
    icon: IconSparkles,
    iconClass: "text-purple-600",
    title: "More to come",
    description:
      "Exciting new benefits and features are on the way for our members.",
  },
]
---

<Default title="MobiFlight Club — Fly Further Together">
  <Hero
    headline="Join the MobiFlight Club — Fly Further Together"
    tagline="For the builders, tinkerers, and sim pilots who want more."
    ctas={[
      { text: "Become a Member", link: clubSignupUrl, variant: "primary" },
      { text: "Login", link: clubLoginUrl, variant: "outline" },
    ]}
    imageSrc={heroImage.src}
  />

  <Container>
    <section class="pt-8">
      <h2 class="text-3xl font-bold mb-4">What is the MobiFlight Club?</h2>
      <p class="mb-6 text-lg">
        Join the MobiFlight Club and help keep MobiFlight free and open source.
        Your monthly contribution fuels development and ensures sustainability.
        As a thank-you, you'll get a voice in feature priorities, exclusive
        coupons, and early access to our newsletter.
      </p>
      <p class="text-muted-foreground">
        Take a look at the benefits below, and join us in building the future of
        flight sim!
      </p>
    </section>
  </Container>

  <!-- Benefits -->
  <Container>
    <section class="py-8">
      <h2 class="text-3xl font-bold mb-6">Member Benefits</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          benefits.map((b) => (
            <li class="flex gap-4 p-4 border rounded-lg items-center">
              <span class={`text-3xl ${b.iconClass} [&_svg]:size-10`}>
                {<b.icon class="w-10 h-10" />}
              </span>
              <div>
                <h3 class="font-semibold text-lg">{b.title}</h3>
                <p class="text-muted-foreground">{b.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </section>
  </Container>

  <!-- Member sign up -->
  <Container class="mb-16">
    <MemberJoinBox />
</Default>

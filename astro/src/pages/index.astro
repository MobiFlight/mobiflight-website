---
import Default from "../layouts/default.astro"
import Hero from "@/components/mobiflight/hero.astro"
import Container from "@/components/mobiflight/container.astro"
import NewsCard from "@/components/mobiflight/news-card.astro"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card"

const heroImage = "https://shop.mobiflight.com/wp-content/uploads/2026/02/homepage-mcp.jpg"

const valueCards = [
  {
    title: "Plug-and-play and DIY friendly",
    teaser: "Start with off-the-shelf hardware or build your own cockpit panels with Arduino and Raspberry Pi.",
  },
  {
    title: "Works with major simulators",
    teaser: "Control your setup in Microsoft Flight Simulator, X-Plane, and other leading simulation platforms.",
  },
  {
    title: "Open source and community-driven",
    teaser: "Use MobiFlight for free, improve it together, and learn from one of the most active sim communities.",
  },
  {
    title: "From first switch to full cockpit",
    teaser: "Scale from a small home setup to complex multi-module cockpits with one consistent toolchain.",
  },
]

const latestNews = [
  {
    date: "March 15, 2026",
    title: "MobiFlight v11 Released",
    teaser: "Fresh new look, redesigned UI, new project concepts and easier sharing. The biggest release ever.",
    href: "/download",
  },
  {
    date: "February 10, 2026",
    title: "FSWeekend 2026 Recap",
    teaser: "We had an amazing time meeting the community. Thank you to everyone who stopped by.",
    href: "/news",
  },
  {
    date: "January 5, 2026",
    title: "New Hardware Support Added",
    teaser: "Raspberry Pi Pico W and several new Arduino-compatible boards are now fully supported.",
    href: "/news",
  },
]
---

<Default title="MobiFlight — Soar Higher with the Ultimate Flight Sim Hardware Companion">
  <Hero
    headline="Manage your flight sim hardware"
    tagline="Easy. Free. 100% Open Source."
    ctaText="Download Free"
    ctaLink="/download"
    imageSrc={heroImage}
  />

  <!-- Value Proposition -->
  <Container>
    <section class="py-8">
      <h2 class="text-3xl font-bold mb-2">Built for simmers at every level</h2>
      <p class="text-muted-foreground mb-6 max-w-3xl">
        Whether you are setting up your first panel or engineering a full custom cockpit, MobiFlight keeps your hardware under control.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {valueCards.map((item) => (
          <Card>
            <CardHeader>
              <CardTitle>{item.title}</CardTitle>
            </CardHeader>
            <CardContent>
              <CardDescription>{item.teaser}</CardDescription>
            </CardContent>
          </Card>
        ))}
      </div>
    </section>
  </Container>

  <!-- News & Updates -->
  <Container>
    <section class="py-8 border-t">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-6">
        <div>
          <h2 class="text-3xl font-bold mb-2">News & Updates</h2>
          <p class="text-muted-foreground">Latest announcements, releases, and community highlights.</p>
        </div>
        <a href="/news" class="text-primary font-semibold underline">Take me to the news →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {latestNews.map((entry) => (
          <NewsCard {...entry} />
        ))}
      </div>
    </section>
  </Container>

  <!-- Quick Navigation Hub -->
  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-6">Everything MobiFlight</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <a href="https://docs.mobiflight.com" target="_blank" rel="noopener noreferrer" class="p-4 border rounded-lg hover:bg-muted transition-colors">📖 Documentation</a>
        <a href="https://shop.mobiflight.com" target="_blank" rel="noopener noreferrer" class="p-4 border rounded-lg hover:bg-muted transition-colors">🛒 Shop</a>
        <a href="https://mobiflight.com/discord" target="_blank" rel="noopener noreferrer" class="p-4 border rounded-lg hover:bg-muted transition-colors">💬 Community (Discord)</a>
        <a href="https://hubhop.mobiflight.com" target="_blank" rel="noopener noreferrer" class="p-4 border rounded-lg hover:bg-muted transition-colors">✈️ HubHop Presets</a>
        <a href="/club" class="p-4 border rounded-lg hover:bg-muted transition-colors">⭐ MobiFlight Club</a>
        <a href="/services" class="p-4 border rounded-lg hover:bg-muted transition-colors">🤝 Professional Services</a>
      </div>
    </section>
  </Container>

  <!-- Sponsor Wall -->
  <Container>
    <section class="py-8 border-t">
      <h2 class="text-3xl font-bold mb-2">Powered by Our Sponsors</h2>
      <p class="text-muted-foreground mb-6">MobiFlight is free because of the amazing people and companies who support it.</p>
      <div class="flex flex-wrap gap-4 mb-6">
        <div class="px-6 py-4 border rounded-lg text-muted-foreground">Your logo here</div>
        <div class="px-6 py-4 border rounded-lg text-muted-foreground">Your logo here</div>
        <div class="px-6 py-4 border rounded-lg text-muted-foreground">Your logo here</div>
      </div>
      <a href="https://github.com/sponsors/MobiFlight" target="_blank" rel="noopener noreferrer" class="underline text-primary font-semibold">Become a Sponsor →</a>
    </section>
  </Container>
</Default>
---
import Default from "../layouts/default.astro"
import Hero from "@/components/mobiflight/hero.astro"
import Container from "@/components/mobiflight/container.astro"
import Button from "@/components/starwind/button/Button.astro"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card"
import IconDownload from "@/components/mobiflight/icons/icon-download.astro"
import IconGithub from "@/components/mobiflight/icons/icon-github.astro"
import IconDiscord from "@/components/mobiflight/icons/icon-discord.astro"
import IconTrophy from "@/components/mobiflight/icons/icon-trophy.astro"
import IconUsersGroup from "@/components/mobiflight/icons/icon-users-group.astro"
import IconShare from "@/components/mobiflight/icons/icon-share.astro"
import IconActivity from "@/components/mobiflight/icons/icon-activity.astro"

import heroImage from "@/images/hero-project.jpg"
import flightSimAwardImage from "@/images/about/fsweekend-award2026.jpg"
import { Image } from "astro:assets"

const facts = [
  {
    class: "text-yellow-500",
    icon: IconTrophy,
    value: "Award Winner",
    teaser: "Flight Sim Award for best DIY hardware and tooling",
  },
  {
    class: "text-teal-600",
    icon: IconUsersGroup,
    value: "14,000+",
    teaser: "registered Discord community members",
  },
  {
    class: "text-green-700",
    icon: IconShare,
    value: "30,000+",
    teaser: "shared presets and profiles",
  },
  {
    class: "text-purple-700",
    icon: IconActivity,
    value: "18,000+",
    teaser: "monthly active users in the app",
  },
]
---

<Default title="MobiFlight Project">
  <Hero
    headline="By the community, for the community"
    tagline="MobiFlight is a free, open-source project built by a passionate team and supported by an active global community of flight sim enthusiasts."
    ctas={[
      {
        icon: IconDownload,
        text: "Download MobiFlight",
        link: "/download",
        variant: "primary",
      },
    ]}
    imageSrc={heroImage.src}
  />

  <Container>
    <section class="py-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="flex flex-col gap-8">
          <h2 class="text-3xl font-bold">
            From DIY solution to universal controller ecosystem
          </h2>
          <p class="text-lg">
            MobiFlight was originally created as a small tool by the founder,
            Sebastian, to help him build a custom flight simulator cockpit.
          </p>
          <p class="text-muted-foreground">
            It quickly gained popularity among flight simulation enthusiasts,
            allowing users to build self-built cockpit panels and controllers in
            an inexpensive way., and integrate them into simulators without
            special expertise.
          </p>
          <p class="text-muted-foreground">
            Over time, it evolved into something bigger: a flexible,
            user-friendly control center for all kinds of flight sim
            controllers, backed by an active community with thousands of users
            worldwide and a strong open-source mindset.
          </p>
        </div>
        <div>
          <Image
            class="rounded-lg object-cover"
            format="webp"
            src={flightSimAwardImage}
            alt="Flight Sim Award"
          />
        </div>
      </div>
    </section>
  </Container>

  <Container>
    <section class="py-10 border-t">
      <h2 class="text-3xl font-bold mb-8">The people behind it</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="border rounded-xl p-6">
          <h3 class="text-xl font-semibold mb-3">
            A dedicated team with a shared passion
          </h3>
          <p class="text-muted-foreground mb-4">
            MobiFlight is led by its founder Sebastian, full-time, supported by
            a group of dedicated moderators and code contributors. We are all
            people who care deeply about flight simulation and believe great
            tooling should be free and open.
          </p>
          <Button
            href="https://github.com/MobiFlight"
            target="_blank"
            rel="noopener noreferrer"
            variant="outline"
            class="[&>svg]:size-4"
          >
            <IconGithub />
            See contributors on GitHub
          </Button>
        </div>
        <div class="border rounded-xl p-6">
          <h3 class="text-xl font-semibold mb-3">
            A community of 14,000 and growing
          </h3>
          <p class="text-muted-foreground mb-4">
            The community is what makes MobiFlight extraordinary. Members share
            presets and hardware builds, answer questions, file bug reports, and
            help newcomers get their first controller working within hours.
          </p>
          <Button
            href="https://mobiflight.com/discord"
            target="_blank"
            rel="noopener noreferrer"
            variant="secondary"
            class="[&>svg]:size-4"
          >
            <IconDiscord />
            Join the Discord server
          </Button>
        </div>
      </div>
    </section>
  </Container>

  <div class="w-full bg-muted">
    <Container>
      <section class="py-10 border-t">
        <h2 class="text-3xl font-bold mb-2">The numbers tell the story</h2>
        <p class="text-muted-foreground mb-6">
          MobiFlight is a well-established, thriving open-source project. Many
          thousands of users are benefiting from its features and active
          community. A great number also contributes back in the form of
          presets, shared knowledge, software development, and direct support.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
          {
            facts.map((item) => (
              <Card>
                <CardHeader>
                  <CardTitle class={`text-2xl [&>svg]:size-14 [&>svg]:stroke-2 font-extrabold items-center flex flex-col ${item.class}`}>
                    <item.icon />
                    {item.value}
                  </CardTitle>
                </CardHeader>
                <CardContent>
                  <CardDescription>{item.teaser}</CardDescription>
                </CardContent>
              </Card>
            ))
          }
        </div>
      </section>
    </Container>
  </div>

  <Container>
    <section class="py-10 border-t">
      <h2 class="text-3xl font-bold mb-2">How you can get involved</h2>
      <p class="text-muted-foreground mb-8 max-w-3xl">
        <span class="font-bold">Every contribution matters.</span>
        Open source is powered by people — and there is no single right way to contribute.
        Every member of the community finds their own path, and every contribution
        moves the project forward.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <article class="border rounded-xl p-5">
          <h3 class="text-lg font-semibold mb-2">Write code</h3>
          <p class="text-muted-foreground text-sm">
            Developers contribute to the app, connector libraries, and the
            websites that power the MobiFlight ecosystem.
          </p>
        </article>
        <article class="border rounded-xl p-5">
          <h3 class="text-lg font-semibold mb-2">Report bugs</h3>
          <p class="text-muted-foreground text-sm">
            Documenting an issue and helping reproduce it is how problems get
            fixed. Every bug report makes MobiFlight more reliable.
          </p>
        </article>
        <article class="border rounded-xl p-5">
          <h3 class="text-lg font-semibold mb-2">Create presets on HubHop</h3>
          <p class="text-muted-foreground text-sm">
            Sharing your aircraft and controller presets on HubHop means
            thousands of others can benefit from your work immediately.
          </p>
        </article>
        <article class="border rounded-xl p-5">
          <h3 class="text-lg font-semibold mb-2">Suggest new features</h3>
          <p class="text-muted-foreground text-sm">
            Great ideas come from real users. Filing a feature request on GitHub
            shapes what MobiFlight becomes next.
          </p>
        </article>
        <article class="border rounded-xl p-5">
          <h3 class="text-lg font-semibold mb-2">Help others on Discord</h3>
          <p class="text-muted-foreground text-sm">
            Answering questions, sharing your experience, and welcoming
            newcomers keeps the community strong and growing.
          </p>
        </article>
        <article class="border rounded-xl p-5">
          <h3 class="text-lg font-semibold mb-2">Share your project</h3>
          <p class="text-muted-foreground text-sm">
            Build logs, 3D models, wiring plans, and best practices shared with
            the community inspire others and move the hobby forward.
          </p>
        </article>
      </div>
    </section>
  </Container>

  <Container>
    <section class="py-10 border-t">
      <h2 class="text-3xl font-bold mb-2">Why people trust the project</h2>
      <p class="text-muted-foreground mb-6 max-w-3xl">
        Trust comes from openness, helpful community members, and a project that
        keeps getting better with every release.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <article class="border rounded-xl p-5">
          <h3 class="text-xl font-semibold mb-2">
            Free to use and open source
          </h3>
          <p class="text-muted-foreground">
            You can see how the project evolves, follow releases, and benefit
            from a platform that is not locked away behind one vendor.
          </p>
        </article>
        <article class="border rounded-xl p-5">
          <h3 class="text-xl font-semibold mb-2">A huge helpful community</h3>
          <p class="text-muted-foreground">
            Support, presets, shared knowledge, and real build experience make
            the ecosystem much easier to grow into.
          </p>
        </article>
        <article class="border rounded-xl p-5">
          <h3 class="text-xl font-semibold mb-2">Built around real users</h3>
          <p class="text-muted-foreground">
            The project grew from real cockpit-building needs, and provides
            solutions that are practical, flexible, and valuable for every
            flight simmer.
          </p>
        </article>
      </div>
    </section>
  </Container>
</Default>

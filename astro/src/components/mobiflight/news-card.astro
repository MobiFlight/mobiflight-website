---
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card"

interface Props {
  date: string
  title: string
  teaser: string
  href: string
}

const { date, title, teaser, href } = Astro.props
---

<Card>
  <CardHeader>
    <p class="text-sm text-muted-foreground">{date}</p>
    <CardTitle class="text-lg">{title}</CardTitle>
  </CardHeader>
  <CardContent>
    <CardDescription>{teaser}</CardDescription>
  </CardContent>
</Card>

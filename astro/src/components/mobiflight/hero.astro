---
import Button from "@/components/starwind/button/Button.astro"
import Container from "@/components/mobiflight/container.astro"
interface Props {
  headline: string
  tagline: string
  ctaText?: string
  ctaLink?: string
  imageSrc: string
}
const { headline, tagline, ctaText, ctaLink, imageSrc } = Astro.props
---

<section
  class="w-full bg-cover bg-center bg-no-repeat min-h-96"
  style={`background-image: linear-gradient(to bottom right, rgba(17,24,39,0.7), rgba(12,74,110,0.7)), url('${imageSrc}')`}
>
  <Container class="py-8">
    <div class="flex flex-col gap-6 items-start text-white max-w-4xl">
      <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold leading-tight">
        {headline}
      </h1>
      <p class="text-lg sm:text-xl lg:text-2xl">{tagline}</p>
      {ctaText && ctaLink && <Button href={ctaLink}>{ctaText}</Button>}
    </div>
  </Container>
</section>

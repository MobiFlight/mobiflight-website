---
import Container from "@/components/mobiflight/container.astro"
import NewsCard from "@/components/mobiflight/news-card.astro"
import news from "@/data/news.json"
---

<!-- News & Updates -->
<Container>
  <section class="py-8 border-t">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-6">
      <div>
        <h2 class="text-3xl font-bold mb-2">News & Updates</h2>
        <p class="text-muted-foreground">
          Latest announcements, releases, and community highlights.
        </p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {news.map((entry) => <NewsCard {...entry} />)}
    </div>
  </section>
</Container>

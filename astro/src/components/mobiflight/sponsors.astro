---
import Container from "@/components/mobiflight/container.astro"
import sponsorData from "@/data/sponsors.json"

type Sponsor = {
  name: string
  logo: string
  href: string | null
  amount: number
  size: number
}

const sponsors = (sponsorData as Sponsor[]).toSorted((a, b) => {
  if (b.amount !== a.amount) return b.amount - a.amount
  return a.name.localeCompare(b.name)
})

const sizeToClass = (size: number) => {
  if (size >= 180) return "h-44"
  if (size >= 150) return "h-36"
  if (size >= 125) return "h-32"
  if (size >= 110) return "h-28"
  if (size >= 95) return "h-24"
  if (size >= 80) return "h-20"
  return "h-16"
}
---

<!-- Sponsor Wall -->
<Container>
  <section class="py-8 border-t">
    <h2 class="text-3xl font-bold mb-2">Powered by Our Sponsors</h2>
    <p class="text-muted-foreground mb-6">
      MobiFlight is free because of the amazing people and companies who support
      it.
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-6">
      {sponsors.map((sponsor) =>
        sponsor.href ? (
          <a
            href={sponsor.href}
            target="_blank"
            rel="noopener noreferrer"
            title={`Visit the ${sponsor.name} website`}
            class="inline-flex items-center justify-center"
          >
            <img
              src={sponsor.logo}
              alt={`${sponsor.name} logo`}
              class:list={[
                "w-auto max-w-full object-contain hover:grayscale-0 transition-all",
                sizeToClass(sponsor.size),
              ]}
            />
          </a>
        ) : (
          <div class="inline-flex items-center justify-center">
            <img
              src={sponsor.logo}
              alt={`${sponsor.name} logo`}
              class:list={[
                "w-auto max-w-full object-contain",
                sizeToClass(sponsor.size),
              ]}
            />
          </div>
        )
      )}
    </div>
    <a
      href="https://github.com/sponsors/MobiFlight"
      target="_blank"
      rel="noopener noreferrer"
      class="underline text-primary font-semibold">Become a Sponsor →</a
    >
  </section>
</Container>

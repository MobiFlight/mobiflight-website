---
import Button from "@/components/starwind/button/Button.astro"
import IconDocs from "@/components/mobiflight/icons/icon-docs.astro"
import IconShop from "@/components/mobiflight/icons/icon-shop.astro"
import IconDownload from "@/components/mobiflight/icons/icon-download.astro"
---

<div
  class="relative flex justify-center bg-linear-to-br from-sky-500 to-emerald-500 dark:from-indigo-500/10 dark:via-sky-500/0 dark:via-70% dark:to-emerald-500/5"
  data-mobile-nav
>
  <nav
    class="flex flex-row gap-4 px-4 sm:px-6 lg:px-8 py-4 items-center w-full max-w-6xl justify-between font-semibold uppercase text-white"
  >
    <a href="/"
      ><img
        src="https://shop.mobiflight.com/wp-content/uploads/2026/02/mobiflight-logo-wide-small.png"
        alt="MobiFlight"
        class="h-8"
      />
    </a>

    <div
      id="primary-navigation"
      class="hidden md:flex flex-row gap-4 md:gap-6 lg:gap-8 items-center text-sm sm:text-base"
    >
      <a href="/about">Project</a>
      <a href="/club">Membership</a>
      <a href="/services">Services</a>
    </div>
    <div
      id="secondary-navigation"
      class="hidden md:flex flex-row gap-4 lg:gap-8 items-center font-normal normal-case"
    >
      <a
        class="flex items-center gap-1"
        href="https://docs.mobiflight.com"
        target="_blank"
        rel="noopener noreferrer"
        ><IconDocs /><span class="hidden lg:inline">Docs</span></a
      >
      <a
        class="flex items-center gap-1"
        href="https://shop.mobiflight.com"
        target="_blank"
        rel="noopener noreferrer"
        ><IconShop /><span class="hidden lg:inline">Shop</span></a
      >
      <a
        href="https://mobiflight.com/discord"
        target="_blank"
        rel="noopener noreferrer">Support</a
      >
      <Button
        href="/download"
        size="sm"
        class="hidden lg:flex bg-background text-foreground hover:bg-background/80"
        ><IconDownload /> Download</Button
      >
    </div>

    <button
      type="button"
      class="group md:hidden inline-flex flex-col justify-center gap-1.5 w-10 h-10 rounded-lg border border-white/40 bg-black/15 p-2"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation menu"
      data-menu-toggle
    >
      {
        [1, 2, 3].map((i) => (
          <span
            class:list={[
              "block w-full h-0.5 rounded-full bg-white transition-all duration-200 ease-in-out origin-center",
              i === 1 &&
                "group-aria-expanded:translate-y-2 group-aria-expanded:rotate-45",
              i === 2 &&
                "group-aria-expanded:opacity-0 transition-opacity duration-100",
              i === 3 &&
                "group-aria-expanded:-translate-y-2 group-aria-expanded:-rotate-45",
            ]}
            data-menu-line={i}
          />
        ))
      }
    </button>
  </nav>

  <div
    id="mobile-overlay"
    class="fixed inset-0 bg-black/35 z-30 md:hidden"
    hidden
    data-menu-overlay
    aria-hidden="true"
  >
  </div>

  <div
    id="mobile-menu"
    class="absolute top-full left-0 right-0 z-40 p-4 border border-white/20 bg-linear-to-br from-sky-600 to-emerald-600 p-4 shadow-2xl md:hidden"
    hidden
    data-menu-panel
  >
    <div class="flex flex-col gap-3 uppercase font-semibold text-white text-lg">
      <a href="/about">Project</a>
      <a href="/club">Membership</a>
      <a href="/services">Services</a>
    </div>

    <div class="h-px bg-white/20 my-5"></div>

    <div class="flex flex-col gap-3 text-white">
      <a
        class="flex items-center gap-2"
        href="https://docs.mobiflight.com"
        target="_blank"
        rel="noopener noreferrer"><IconDocs /> Docs</a
      >
      <a
        class="flex items-center gap-2"
        href="https://shop.mobiflight.com"
        target="_blank"
        rel="noopener noreferrer"><IconShop /> Shop</a
      >
      <a
        href="https://mobiflight.com/discord"
        target="_blank"
        rel="noopener noreferrer">Support</a
      >
      <Button
        href="/download"
        size="sm"
        class="w-fit bg-background text-foreground hover:bg-background/80"
        ><IconDownload /> Download</Button
      >
    </div>
  </div>
</div>

<script is:inline>
  const root = document.querySelector("[data-mobile-nav]")
  if (root) {
    const toggle = root.querySelector("[data-menu-toggle]")
    const panel = root.querySelector("[data-menu-panel]")
    const overlay = root.querySelector("[data-menu-overlay]")

    const closeMenu = () => {
      toggle?.setAttribute("aria-expanded", "false")
      panel?.setAttribute("hidden", "")
      overlay?.setAttribute("hidden", "")
      document.body.style.overflow = ""
    }

    const openMenu = () => {
      toggle?.setAttribute("aria-expanded", "true")
      panel?.removeAttribute("hidden")
      overlay?.removeAttribute("hidden")
      document.body.style.overflow = "hidden"
    }

    toggle?.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true"
      if (expanded) closeMenu()
      else openMenu()
    })

    overlay?.addEventListener("click", closeMenu)
    panel
      ?.querySelectorAll("a")
      .forEach((link) => link.addEventListener("click", closeMenu))

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) closeMenu()
    })
  }
</script>
